# Atlas Fitness Environment Variables
# Copy this to .env.local and fill in your real values

# Database
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Your Real Meta Ads (Atlas Fitness)
META_ACCESS_TOKEN=your_real_meta_access_token
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_AD_ACCOUNT_ID=act_123456789
META_PAGE_ID=123456789
META_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token

# Your Real Phone Numbers
OWNER_TEST_PHONE=+447700900123  # Your actual mobile for testing
NEXT_PUBLIC_OWNER_TEST_PHONE=+447700900123  # Same, for client-side

# Twilio SMS (Real Account)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+441234567890  # Your Twilio phone number
TWILIO_STATUS_CALLBACK_URL=https://your-domain.vercel.app/api/webhooks/twilio-status

# Stripe (For when you're ready to sell)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# OpenAI (Optional - for AI features)
OPENAI_API_KEY=sk-your_openai_api_key

# Email (Optional - for email automation)
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL=noreply@atlasfitness.co.uk

# Base URL
NEXT_PUBLIC_BASE_URL=https://your-domain.vercel.app

# Atlas Fitness Specific
ATLAS_ORGANIZATION_ID=atlas-fitness-001
ATLAS_OWNER_USER_ID=your-actual-supabase-auth-user-id